{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Run src/app/main.py (IDE debug - host DB)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/app/main.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONDONTWRITEBYTECODE": "1",
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "justMyCode": false
    }
  ]
}