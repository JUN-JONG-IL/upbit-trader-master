# =============================================================================
# 기관급 트레이딩 시스템 - 환경 변수 템플릿
# 버전: v8.0 (DB설계.md 기반)
# 사용법: cp .env.example .env  후 실제 값으로 수정
# =============================================================================

# -----------------------------------------------------------------------------
# Tier 1: Redis (Hot Tier)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=58530
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20

# -----------------------------------------------------------------------------
# Tier 2: TimescaleDB (Warm Tier)
# -----------------------------------------------------------------------------
# TimescaleDB 컨테이너 내부 설정
POSTGRES_USER_CONTAINER=postgres
POSTGRES_PASSWORD_CONTAINER=postgres
POSTGRES_DB_CONTAINER=upbit_trader

# 앱에서 TimescaleDB 연결 (컨테이너 외부)
TIMESCALE_HOST=localhost
TIMESCALE_PORT=58529
TIMESCALE_DB=upbit_trader
TIMESCALE_USER=postgres
TIMESCALE_PASSWORD=postgres
TIMESCALE_MIN_POOL=5
TIMESCALE_MAX_POOL=20

# -----------------------------------------------------------------------------
# Tier 3: PostgreSQL Primary - CQRS Event Store (Core Tier)
# -----------------------------------------------------------------------------
POSTGRES_PRIMARY_HOST=localhost
POSTGRES_PRIMARY_PORT=5433
POSTGRES_PRIMARY_DB=trading
POSTGRES_PRIMARY_USER=trader
POSTGRES_PRIMARY_PASSWORD=change_me_strong_password

# PostgreSQL Replica (읽기 전용 CQRS)
POSTGRES_REPLICA_HOST=localhost
POSTGRES_REPLICA_PORT=5434
POSTGRES_REPLICA_DB=trading
POSTGRES_REPLICA_USER=trader
POSTGRES_REPLICA_PASSWORD=change_me_strong_password

# -----------------------------------------------------------------------------
# Tier 4: Kafka (Event Streaming)
# -----------------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_ZOOKEEPER=localhost:2181
KAFKA_GROUP_ID=upbit-trader
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_COMPRESSION_TYPE=lz4

# Kafka 토픽 설정
KAFKA_TOPIC_TICKER=ticker.raw
KAFKA_TOPIC_ORDERBOOK=orderbook.raw
KAFKA_TOPIC_TRADE=trade.raw
KAFKA_TOPIC_CANDLE_1M=candle.1m
KAFKA_TOPIC_CANDLE_5M=candle.5m
KAFKA_TOPIC_CANDLE_1H=candle.1h
KAFKA_TOPIC_TRADING_EVENTS=trading.events
KAFKA_TOPIC_ORDER_CREATED=order.created
KAFKA_TOPIC_ORDER_FILLED=order.filled

# -----------------------------------------------------------------------------
# MongoDB (메타데이터 + 설정)
# -----------------------------------------------------------------------------
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=upbit_trader
MONGO_INITDB_ROOT_USERNAME_CONTAINER=trader
MONGO_INITDB_ROOT_PASSWORD_CONTAINER=change_me_strong_password
MONGO_INITDB_ROOT_USERNAME=trader
MONGO_INITDB_ROOT_PASSWORD=change_me_strong_password
# 또는 전체 URI 직접 지정 (위 개별 설정보다 우선)
# MONGO_URI=mongodb://trader:password@localhost:27017/upbit_trader?authSource=admin

# -----------------------------------------------------------------------------
# ClickHouse (Cold Tier - 장기 분석)
# -----------------------------------------------------------------------------
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DB=trading
CLICKHOUSE_USER=trader
CLICKHOUSE_PASSWORD=change_me_strong_password

# -----------------------------------------------------------------------------
# Upbit API 인증
# -----------------------------------------------------------------------------
UPBIT_ACCESS_KEY=your_upbit_access_key_here
UPBIT_SECRET_KEY=your_upbit_secret_key_here

# -----------------------------------------------------------------------------
# 데이터 저장 경로
# -----------------------------------------------------------------------------
DATA_DIR=./data
LOG_DIR=./logs

# -----------------------------------------------------------------------------
# 파이프라인 설정
# -----------------------------------------------------------------------------
PIPELINE_BATCH_SIZE=1000
PIPELINE_FLUSH_INTERVAL=5
REDIS_PIPELINE_BATCH=100
GAP_CHECK_INTERVAL=60

# -----------------------------------------------------------------------------
# AI/ML (선택 기능)
# -----------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
FEAST_REPO_PATH=./feast_repo

# -----------------------------------------------------------------------------
# 모니터링
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
JAEGER_HOST=localhost
JAEGER_PORT=6831

# -----------------------------------------------------------------------------
# 보안
# -----------------------------------------------------------------------------
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=
JWT_SECRET_KEY=change_me_jwt_secret_key_here
