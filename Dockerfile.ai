# Dockerfile.ai — AI/ML engine service image
# Build:  docker build -f Dockerfile.ai -t upbit-ai .
# Run:    docker run --env-file .env upbit-ai
# NOTE: This Dockerfile is standalone.  Development workflow runs the app
#       directly from the IDE; this file is for containerised deployment.
# -------------------------------------------------------------------------

FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    APP_HOME=/app

WORKDIR ${APP_HOME}

# System dependencies
RUN set -eux; \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
        wget \
        curl \
        ca-certificates \
        libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Install TA-Lib C library
RUN wget -q http://prdownloads.sourceforge.net/ta-lib/ta-lib-0.4.0-src.tar.gz && \
    tar -xzf ta-lib-0.4.0-src.tar.gz && \
    cd ta-lib/ && \
    ./configure --prefix=/usr && \
    make -j$(nproc) && \
    make install && \
    cd .. && \
    rm -rf ta-lib ta-lib-0.4.0-src.tar.gz

# Python dependencies
COPY requirements.txt /tmp/requirements.txt
RUN pip install --upgrade pip setuptools wheel && \
    pip install --no-cache-dir \
        scikit-learn>=1.3.0 \
        xgboost>=2.0.0 \
        lightgbm>=4.6.0 \
        torch>=2.0.0 \
        transformers>=4.30.0 \
        mlflow>=3.5.0 \
        optuna>=3.4.0 \
        prophet>=1.1.0 \
        pandas-ta>=0.3.14 \
        TA-Lib>=0.4.28 \
        motor>=3.0 \
        "redis>=4.6" \
        fastapi>=0.70.0 \
        uvicorn[standard]>=0.18.0 \
        aiohttp>=3.9.0 \
        pandas==2.2.3 \
        numpy>=1.23

# Copy application source
COPY src/06_ai ${APP_HOME}/src/06_ai
COPY src/01_core ${APP_HOME}/src/01_core
COPY src/__init__.py ${APP_HOME}/src/__init__.py

# Non-root user
RUN groupadd --gid 1000 aiuser && \
    useradd --uid 1000 --gid aiuser --shell /bin/bash --create-home aiuser && \
    chown -R aiuser:aiuser ${APP_HOME}

USER aiuser

EXPOSE 8080

CMD ["python", "-m", "uvicorn", "src.06_ai.ai_engine.engine.model_server:app", \
     "--host", "0.0.0.0", "--port", "8080"]
