  <property name="windowTitle">
   <string>회원 로그인</string>
  </property>
  <property name="styleSheet">
   <string notr="true"><![CDATA[
/* 전체 배경 */
QWidget#Form {
	background-color: #0f172a;
	color: #e5e7eb;
}

/* 중앙 카드 */
QFrame#login_card {
	background-color: rgba(2, 6, 23, 0.55);
	border: 1px solid rgba(148, 163, 184, 0.18);
	border-radius: 18px;
}

/* 제목 */
QLabel#label_title {
	color: #f9fafb;
	font-weight: 700;
}

/* 입력 */
QLineEdit#lineEdit_access,
QLineEdit#lineEdit_secret {
	background-color: rgba(15, 23, 42, 0.9);
	border: 1px solid rgba(148, 163, 184, 0.22);
	border-radius: 12px;
	padding: 12px 14px;
	color: #e5e7eb;
}
QLineEdit#lineEdit_access:focus,
QLineEdit#lineEdit_secret:focus {
	border: 1px solid rgba(96, 165, 250, 0.95);
}

/* 체크박스 */
QCheckBox#checkBox_save_user { color: rgba(229, 231, 235, 0.9); }
QCheckBox::indicator {
	width: 18px; height: 18px;
	border-radius: 6px;
	border: 1px solid rgba(148, 163, 184, 0.35);
	background-color: rgba(15, 23, 42, 0.9);
}
QCheckBox::indicator:checked {
	background-color: rgba(96, 165, 250, 0.95);
	border: 1px solid rgba(96, 165, 250, 0.95);
}

/* 로그인 버튼 */
QPushButton#pushButton_connect {
	background-color: rgba(96, 165, 250, 0.95);
	color: #0b1220;
	border: none;
	border-radius: 12px;
	padding: 12px 14px;
	font-weight: 700;
}
QPushButton#pushButton_connect:hover { background-color: rgba(59, 130, 246, 0.98); }
QPushButton#pushButton_connect:pressed { background-color: rgba(37, 99, 235, 0.98); }

/* 보조 버튼 */
QPushButton#btn_signup,
QPushButton#btn_find_id,
QPushButton#btn_find_pw,
QPushButton#btn_edit_profile {
	background-color: transparent;
	border: none;
	color: rgba(226, 232, 240, 0.9);
	padding: 6px 8px;
	text-align: left;
}
QPushButton#btn_signup:hover,
QPushButton#btn_find_id:hover,
QPushButton#btn_find_pw:hover,
QPushButton#btn_edit_profile:hover {
	color: rgba(96, 165, 250, 0.95);
}

/* 안내 문구 */
QLabel#label_hint { color: rgba(148, 163, 184, 0.95); }

/* 하단 */
QFrame#bottom {
	background-color: rgba(2, 6, 23, 0.75);
	border-top: 1px solid rgba(148, 163, 184, 0.12);
}
QLabel#label_credits { color: rgba(148, 163, 184, 0.75); }
]]></string>
