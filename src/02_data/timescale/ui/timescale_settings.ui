      <!-- ===== 탭 5: 📊 성능 튜닝 ===== -->
      <widget class="QWidget" name="tabPerformanceTuning">
       <attribute name="title">
        <string>📊 성능 튜닝</string>
       </attribute>
       <layout class="QVBoxLayout" name="verticalLayout_tuning">

        <item>
         <widget class="QGroupBox" name="groupBoxQueryStats">
          <property name="title">
           <string>쿼리 성능 통계</string>
          </property>
          <layout class="QVBoxLayout" name="vLayout_queryStats">
           <item>
            <widget class="QTableWidget" name="tableQueryStats">
             <property name="editTriggers">
              <set>QAbstractItemView::NoEditTriggers</set>
             </property>
             <property name="alternatingRowColors">
              <bool>true</bool>
             </property>
             <column><property name="text"><string>쿼리</string></property></column>
             <column><property name="text"><string>호출 수</string></property></column>
             <column><property name="text"><string>평균(ms)</string></property></column>
             <column><property name="text"><string>최대(ms)</string></property></column>
            </widget>
           </item>
          </layout>
         </widget>
        </item>

       </layout>
      </widget>

      <!-- ===== 탭 6: 🔔 알림 설정 ===== -->
      <widget class="QWidget" name="tabAlertSettings">
       <attribute name="title">
        <string>🔔 알림 설정</string>
       </attribute>
       <layout class="QVBoxLayout" name="verticalLayout_alerts">

        <item>
         <widget class="QGroupBox" name="groupBoxAlertThresholds">
          <property name="title">
           <string>임계값 설정</string>
          </property>
          <layout class="QFormLayout" name="formLayout_thresholds">

           <item row="0" column="0">
            <widget class="QLabel" name="labelCpuThresholdTitle">
             <property name="text"><string>CPU 사용률 임계값 (%):</string></property>
            </widget>
           </item>
           <item row="0" column="1">
            <widget class="QSpinBox" name="spinCpuThreshold">
             <property name="minimum"><number>1</number></property>
             <property name="maximum"><number>100</number></property>
             <property name="value"><number>80</number></property>
            </widget>
           </item>

           <item row="1" column="0">
            <widget class="QLabel" name="labelMemThresholdTitle">
             <property name="text"><string>메모리 사용률 임계값 (%):</string></property>
            </widget>
           </item>
           <item row="1" column="1">
            <widget class="QSpinBox" name="spinMemThreshold">
             <property name="minimum"><number>1</number></property>
             <property name="maximum"><number>100</number></property>
             <property name="value"><number>85</number></property>
            </widget>
           </item>

          </layout>
         </widget>
        </item>

        <item>
         <layout class="QHBoxLayout" name="hLayout_alertButtons">
          <item>
           <spacer name="horizontalSpacer_alert">
            <property name="orientation">
             <enum>Qt::Horizontal</enum>
            </property>
            <property name="sizeHint" stdset="0">
             <size>
              <width>40</width>
              <height>20</height>
             </size>
            </property>
           </spacer>
          </item>
          <item>
           <widget class="QPushButton" name="btnSaveAlertSettings">
            <property name="text"><string>💾 저장</string></property>
           </widget>
          </item>
         </layout>
        </item>

       </layout>
      </widget>

      <widget class="QWidget" name="tabDataDelete">
       <attribute name="title"><string>🗑️ 데이터 삭제</string></attribute>
       <layout class="QVBoxLayout" name="vl_dataDelete">
        <item>
         <widget class="QLabel" name="labelDeleteWarning">
          <property name="text"><string>⚠️ 주의: 삭제된 데이터는 복구할 수 없습니다!</string></property>
          <property name="styleSheet"><string notr="true">color: #E74C3C; font-weight: bold; font-size: 11pt;</string></property>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="groupDeleteCandles">
          <property name="title"><string>📊 candles 테이블</string></property>
          <layout class="QHBoxLayout">
           <item><widget class="QLabel" name="labelCandlesCount"><property name="text"><string>건수: 조회 중...</string></property></widget></item>
           <item>
            <widget class="QPushButton" name="btn_delete_candles_all">
             <property name="text"><string>🗑️ 전체 삭제</string></property>
             <property name="styleSheet"><string notr="true">background-color: #E74C3C; color: white; font-weight: bold;</string></property>
            </widget>
           </item>
           <item>
            <widget class="QPushButton" name="btn_delete_candles_by_symbol">
             <property name="text"><string>심볼별 삭제</string></property>
             <property name="styleSheet"><string notr="true">background-color: #E67E22; color: white; font-weight: bold;</string></property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="groupDeleteStaging">
          <property name="title"><string>⏳ staging_candles 테이블</string></property>
          <layout class="QHBoxLayout">
           <item><widget class="QLabel" name="labelStagingCount"><property name="text"><string>건수: 조회 중...</string></property></widget></item>
           <item>
            <widget class="QPushButton" name="btn_delete_staging_all">
             <property name="text"><string>🗑️ 전체 삭제</string></property>
             <property name="styleSheet"><string notr="true">background-color: #E74C3C; color: white; font-weight: bold;</string></property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="groupDeleteIsolated">
          <property name="title"><string>🔴 isolated_candles 테이블</string></property>
          <layout class="QHBoxLayout">
           <item><widget class="QLabel" name="labelIsolatedCount"><property name="text"><string>건수: 조회 중...</string></property></widget></item>
           <item>
            <widget class="QPushButton" name="btn_delete_isolated_all">
             <property name="text"><string>🗑️ 전체 삭제</string></property>
             <property name="styleSheet"><string notr="true">background-color: #E74C3C; color: white; font-weight: bold;</string></property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="groupDeleteBySymbol">
          <property name="title"><string>🎯 특정 심볼 데이터 삭제</string></property>
          <layout class="QHBoxLayout">
           <item><widget class="QLabel"><property name="text"><string>심볼:</string></property></widget></item>
           <item><widget class="QLineEdit" name="edit_delete_symbol"><property name="placeholderText"><string>예: KRW-BTC</string></property></widget></item>
           <item>
            <widget class="QPushButton" name="btn_delete_symbol_data">
             <property name="text"><string>🗑️ 해당 심볼 삭제</string></property>
             <property name="styleSheet"><string notr="true">background-color: #E74C3C; color: white; font-weight: bold;</string></property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Vertical</enum></property>
          <property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property>
         </spacer>
        </item>
       </layout>
      </widget>

    </widget>
   </item>

   <!-- 닫기 버튼 -->
   <item>
    <widget class="QDialogButtonBox" name="buttonBox">
     <property name="orientation">
      <enum>Qt::Horizontal</enum>
     </property>
     <property name="standardButtons">
      <set>QDialogButtonBox::Close</set>
     </property>
    </widget>
   </item>
  </layout>
 </widget>
 <resources/>
 <connections>
  <connection>
   <sender>buttonBox</sender>
   <signal>rejected()</signal>
   <receiver>TimescaleSettingsDialog</receiver>
   <slot>reject()</slot>
   <hints>
    <hint type="sourcelabel"><x>450</x><y>630</y></hint>
    <hint type="destinationlabel"><x>450</x><y>325</y></hint>
   </hints>
  </connection>
