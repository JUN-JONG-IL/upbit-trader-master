      <!-- ===== 탭 2: 📡 실시간 통신 모니터 ===== -->
      <widget class="QWidget" name="tabRealtimeMonitor">
       <attribute name="title">
        <string>📡 실시간 통신 모니터</string>
       </attribute>
       <layout class="QVBoxLayout" name="verticalLayout_realtime">

        <!-- Live Query Log 테이블 -->
        <item>
         <widget class="QTableWidget" name="table_live_log">
          <property name="editTriggers">
           <set>QAbstractItemView::NoEditTriggers</set>
          </property>
          <property name="alternatingRowColors">
           <bool>true</bool>
          </property>
          <property name="selectionBehavior">
           <enum>QAbstractItemView::SelectRows</enum>
          </property>
          <column><property name="text"><string>시간</string></property></column>
          <column><property name="text"><string>타입</string></property></column>
          <column><property name="text"><string>쿼리</string></property></column>
          <column><property name="text"><string>응답(ms)</string></property></column>
          <column><property name="text"><string>상태</string></property></column>
         </widget>
        </item>

        <!-- PyQtGraph 차트 컨테이너 -->
        <item>
         <widget class="QWidget" name="widget_live_chart_container">
          <property name="minimumSize">
           <size>
            <width>0</width>
            <height>200</height>
           </size>
          </property>
         </widget>
        </item>

       </layout>
      </widget>

