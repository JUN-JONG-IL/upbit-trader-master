      <widget class="QWidget" name="tabDataDelete">
       <attribute name="title"><string>🗑️ 데이터 삭제</string></attribute>
       <layout class="QVBoxLayout" name="vl_kafkaDelete">
        <item>
         <widget class="QLabel" name="labelDeleteWarning_kafka">
          <property name="text"><string>⚠️ 주의: 삭제된 토픽은 복구할 수 없습니다!</string></property>
