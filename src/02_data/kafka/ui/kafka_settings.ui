         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="groupKafkaTopicDelete">
          <property name="title"><string>🗑️ 토픽 삭제</string></property>
          <layout class="QVBoxLayout">
           <item>
            <layout class="QHBoxLayout">
             <item>
