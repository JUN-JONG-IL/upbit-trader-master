   <!-- Header: Title / Uptime / Overall status (수정됨: DB 버튼 행을 아래에 추가) -->
   <item>
    <widget class="QFrame" name="frame_header">
     <property name="frameShape"><enum>QFrame::StyledPanel</enum></property>
     <layout class="QHBoxLayout" name="hLayout_header">
      <item>
       <widget class="QLabel" name="label_header_title">
        <property name="font"><font><family>맑은 고딕</family><pointsize>16</pointsize><weight>75</weight><bold>true</bold></font></property>
        <property name="text"><string>시스템 상태 모니터</string></property>
       </widget>
      </item>

      <!-- spacer between title and right block -->
      <item><spacer name="horizontalSpacer_header"/></item>

      <!-- Right block: vertical stack (top: uptime/overall, bottom: DB buttons row) -->
      <item>
       <widget class="QWidget" name="header_right_container">
        <layout class="QVBoxLayout" name="vLayout_header_right">
         <property name="spacing"><number>6</number></property>

         <!-- top row: uptime and overall status -->
