<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>StatusWidget</class>
 <widget class="QWidget" name="StatusWidget">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>1536</width><height>864</height></rect>
  </property>
  <property name="minimumSize"><size><width>1536</width><height>864</height></size></property>
  <property name="font"><font><family>맑은 고딕</family><pointsize>10</pointsize></font></property>
  <property name="windowTitle"><string>기관급 트레이딩 시스템 — 통합 시스템 모니터</string></property>

  <property name="styleSheet">
   <string notr="true">
QWidget { background-color: #FFFFFF; color: #000000; font-family: '맑은 고딕', 'Segoe UI', sans-serif; }
QTabWidget::pane { border: 1px solid #D0D0D0; background-color: #FFFFFF; padding: 6px; margin-top: 6px; }
QTabBar::tab { background-color: #F8F8F8; color: #222222; padding: 4px 10px; margin-right: 4px; border: 1px solid #E0E0E0; border-bottom: none; border-top-left-radius:4px; border-top-right-radius:4px; }
QTabBar::tab:selected { background-color: #007AFF; color: #FFFFFF; font-weight: bold; }
QTableWidget { background-color: #FFFFFF; color: #000000; gridline-color: #E8E8E8; alternate-background-color: #FBFBFB; }
QHeaderView::section { background-color: #F0F0F0; color: #000000; border: 1px solid #E0E0E0; padding: 4px; font-weight: bold; }
QGroupBox { border: 1px solid #E0E0E0; border-radius: 4px; margin-top: 10px; color: #111111; font-weight: bold; padding: 6px; }
QPushButton { border-radius: 4px; padding: 4px 12px; font-weight: bold; }
QLabel.statusChip { background-color: #FF9500; color: #FFF; padding: 3px 8px; border-radius: 10px; font-size:9pt; }
QLabel.statusOK { background-color: #4CAF50; color:#FFF; padding:2px 6px; border-radius:6px; }
QLabel.statusErr { background-color:#FF3B30;color:#FFF;padding:2px 6px;border-radius:6px; }
QProgressBar { border: 1px solid #E0E0E0; border-radius: 4px; text-align: center; background-color: #F6F6F6; color: #000000; }
QProgressBar::chunk { background-color: #34C759; border-radius: 3px; }
   </string>
  </property>

  <!-- Main vertical layout -->
  <layout class="QVBoxLayout" name="verticalLayout_main">
   <property name="spacing"><number>8</number></property>
   <property name="leftMargin"><number>8</number></property>
   <property name="topMargin"><number>8</number></property>
   <property name="rightMargin"><number>8</number></property>
   <property name="bottomMargin"><number>8</number></property>

   <!-- TOP TOOLBAR: (수정된 블록: 툴바에서 DB 버튼 제거, 새로고침은 유지) -->
   <item>
    <widget class="QFrame" name="frame_toolbar">
     <property name="frameShape"><enum>QFrame::NoFrame</enum></property>
     <property name="styleSheet">
      <string notr="true">
QFrame#frame_toolbar { background-color: #FFFFFF; border-bottom: 1px solid #DCDCDC; padding: 6px; }
QPushButton.compact { background-color:#FFFFFF;color:#111111;border:1px solid #D0D0D0;padding:4px 10px;border-radius:6px;min-height:24px;font-size:9pt; }
QPushButton.compact:hover { background-color:#F3F8FF; }
QPushButton.dbPill { background-color:#FFB84D;color:#ffffff;border:1px solid #EAA23B;padding:4px 12px;border-radius:14px;font-weight:600; min-height:28px; }
QLabel.blackChip { background-color:#000000; min-width:40px; min-height:28px; border-radius:4px; }
QPushButton.refreshBlue { background-color:#007AFF;color:#FFFFFF;border:1px solid #0063D9;padding:6px 10px;border-radius:6px;min-height:30px; font-weight:600; }
      </string>
     </property>
     <layout class="QHBoxLayout" name="hLayout_toolbar">
      <property name="spacing"><number>8</number></property>

      <!-- Left: 기능 버튼 그룹 (compact 스타일) -->
      <item>
       <layout class="QHBoxLayout" name="hLayout_tools">
        <property name="spacing"><number>6</number></property>

        <item>
         <widget class="QPushButton" name="btn_collect_settings">
          <property name="text"><string>수집설정</string></property>
          <property name="toolTip"><string>수집 설정 열기 (팝업)</string></property>
          <property name="styleSheet"><string notr="true">background-color:#FFFFFF;color:#111111;border:1px solid #D0D0D0;padding:6px 12px;border-radius:6px;min-height:28px;QPushButton:hover{background-color:#F3F8FF;}</string></property>
         </widget>
        </item>

        <item>
         <widget class="QPushButton" name="btn_smart_scanner">
          <property name="text"><string>스마트 스캐너</string></property>
