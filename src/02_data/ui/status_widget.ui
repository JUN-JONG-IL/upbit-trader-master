         </widget>
        </item>

        <item>
         <widget class="QPushButton" name="btn_data_pipeline">
          <property name="text"><string>데이터 파이프라인</string></property>
          <property name="styleSheet"><string notr="true">background-color:#FFFFFF;color:#111111;border:1px solid #D0D0D0;padding:6px 12px;border-radius:6px;min-height:28px;</string></property>
         </widget>
        </item>

        <item>
         <widget class="QPushButton" name="btn_db_data">
          <property name="text"><string>DB 데이터</string></property>
