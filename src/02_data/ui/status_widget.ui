   <!-- 서비스 연결 상태 -->
   <item>
    <widget class="QGroupBox" name="groupBox_service_conn">
     <property name="title"><string>서비스 연결 상태</string></property>
     <layout class="QVBoxLayout" name="vLayout_service_conn">
