          <layout class="QHBoxLayout" name="hLayout_header_top">
           <item>
            <widget class="QLabel" name="label_uptime">
             <property name="text"><string>업타임: 00:00:00</string></property>
            </widget>
           </item>
           <item><spacer name="spacer_between_uptime_and_status"/></item>
           <item>
            <widget class="QLabel" name="label_overall_status">
             <property name="text"><string>전체 상태: --</string></property>
            </widget>
           </item>
          </layout>
         </item>

         <!-- bottom row: black chip + DB pill buttons (한단계 아래로 내려와 전체 상태 옆에 위치) -->
