   <!-- Main panels (left/center/right) -->
   <item>
    <layout class="QHBoxLayout" name="hLayout_monitoring_panels" stretch="1,2,1">
     <property name="spacing"><number>8</number></property>

     <!-- LEFT: 실시간 데이터 플로우 -->
