          <property name="text"><string>실시간 로그</string></property>
          <property name="styleSheet"><string notr="true">background-color:#FFFFFF;color:#111111;border:1px solid #D0D0D0;padding:6px 12px;border-radius:6px;min-height:28px;</string></property>
         </widget>
        </item>

       </layout>
      </item>

      <!-- spacer to push refresh button to right -->
      <item>
       <spacer name="spacer_toolbar_right">
        <property name="orientation"><enum>Qt::Horizontal</enum></property>
       </spacer>
      </item>

      <!-- Right: 새로고침 버튼만 남김 (DB 버튼들은 헤더 아래로 이동) -->
      <item>
       <layout class="QHBoxLayout" name="hLayout_toolbar_right">
        <property name="spacing"><number>6</number></property>

        <item>
