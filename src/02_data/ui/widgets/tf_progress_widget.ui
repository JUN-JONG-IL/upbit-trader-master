<?xml version="1.0" encoding="UTF-8"?>
<!--
  TFProgressWidget — 타임프레임별 안정권 진행률 위젯의 외곽 컨테이너 (Qt Designer 호환).

  본 .ui 파일은 SRP 규칙( "*.ui 파일은 순수 XML 형식 유지" )을 충족시키기 위한
  외곽 골격만 정의한다. 타임프레임별 행(QProgressBar + 상태칩) 은 런타임에
  TFProgressWidget(.py) 가 동적으로 생성하여 ``rows_host`` QWidget 의 레이아웃에
  추가하므로, 본 파일을 Qt Designer 에서 열어 편집해도 동적 행 자체는 영향받지
  않는다. 제목 / 마진 / placeholder 텍스트만 디자이너에서 조정 가능.

  사용 측에서 uic.loadUi("tf_progress_widget.ui", host_widget) 로 로드하면
  host_widget.rows_host 와 host_widget.label_placeholder 위젯을 얻을 수 있다.
  단, 현 TFProgressWidget 구현은 .ui 를 사용하지 않고 코드만으로 동등한
  레이아웃을 만들므로 본 파일은 *선택적 디자이너 자료* 이다 (비파괴).
-->
<ui version="4.0">
 <class>TFProgressWidget</class>
 <widget class="QWidget" name="TFProgressWidget">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>360</width><height>220</height></rect>
  </property>
  <property name="windowTitle"><string>TF 안정권 진행률</string></property>
  <layout class="QVBoxLayout" name="root_layout">
   <property name="spacing"><number>4</number></property>
   <property name="leftMargin"><number>6</number></property>
   <property name="topMargin"><number>6</number></property>
   <property name="rightMargin"><number>6</number></property>
   <property name="bottomMargin"><number>6</number></property>
   <item>
    <widget class="QGroupBox" name="group_box">
     <property name="title"><string>타임프레임별 안정권 진행률</string></property>
     <layout class="QVBoxLayout" name="group_layout">
      <property name="spacing"><number>4</number></property>
      <property name="leftMargin"><number>6</number></property>
      <property name="topMargin"><number>10</number></property>
      <property name="rightMargin"><number>6</number></property>
      <property name="bottomMargin"><number>6</number></property>
      <item>
       <widget class="QWidget" name="rows_host" native="true">
        <property name="toolTip"><string>런타임에 TFProgressWidget 가 각 타임프레임 행을 동적으로 추가하는 호스트.</string></property>
        <layout class="QGridLayout" name="rows_layout">
         <property name="horizontalSpacing"><number>6</number></property>
         <property name="verticalSpacing"><number>3</number></property>
         <property name="leftMargin"><number>0</number></property>
         <property name="topMargin"><number>0</number></property>
         <property name="rightMargin"><number>0</number></property>
         <property name="bottomMargin"><number>0</number></property>
        </layout>
       </widget>
      </item>
      <item>
       <widget class="QLabel" name="label_placeholder">
        <property name="text"><string>데이터 없음 — MetadataManager 응답 대기 중...</string></property>
        <property name="alignment"><set>Qt::AlignCenter</set></property>
        <property name="visible"><bool>false</bool></property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
  </layout>
 </widget>
 <resources/>
 <connections/>
</ui>
