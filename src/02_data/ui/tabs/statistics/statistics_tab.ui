              </widget>
            </item>

            <item>
              <widget class="QPushButton" name="btn_export_all">
                <property name="text"><string>전체 내보내기</string></property>
              </widget>
            </item>

            <item>
              <widget class="QPushButton" name="btn_clear_selected">
                <property name="text"><string>선택 지우기</string></property>
              </widget>
            </item>

            <item>
              <widget class="QPushButton" name="btn_clear_all">
                <property name="text"><string>전체 지우기</string></property>
              </widget>
            </item>

            <!-- Load history 버튼 (툴팁 포함) -->
            <item>
              <widget class="QPushButton" name="btn_load_history">
                <property name="text"><string>Load history</string></property>
                <property name="toolTip"><string>로그 파일(upbit-trader.log)을 불러옵니다</string></property>
              </widget>
            </item>

            <item>
              <widget class="QPushButton" name="btn_settings">
                <property name="text"><string>설정</string></property>
              </widget>
            </item>

            <item>
              <spacer name="spacer_toolbar_right">
                <property name="orientation"><enum>Qt::Horizontal</enum></property>
              </spacer>
            </item>

            <item>
              <widget class="QLabel" name="lbl_toolbar_status">
                <property name="text"><string>상태: 대기</string></property>
              </widget>
            </item>

          </layout>
        </widget>
