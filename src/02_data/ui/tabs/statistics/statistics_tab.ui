    <!-- 전역 스타일시트: 버튼 강조 (흰색/투명 배경 사용 안함) -->
    <property name="styleSheet">
      <string notr="true"><![CDATA[
/* Top toolbar primary */
QPushButton#btn_pause, QPushButton#btn_refresh, QPushButton#btn_settings {
  background-color: #0ea5a4; color: #ffffff; border: 1px solid #0b7280;
  border-radius: 6px; padding: 4px 8px;
}
QPushButton#btn_export_selected, QPushButton#btn_export_all, QPushButton#btn_load_history {
  background-color: #2563eb; color: #ffffff; border: 1px solid #1e40af;
  border-radius: 6px; padding: 4px 8px;
}
QPushButton#btn_clear_selected, QPushButton#btn_clear_all {
  background-color: #ef4444; color: #ffffff; border: 1px solid #b91c1c;
  border-radius: 6px; padding: 4px 8px;
}
/* Default for other buttons (neutral) */
QPushButton {
  background-color: #111827; color: #ffffff; border: 1px solid #374151;
  border-radius: 6px; padding: 4px 6px;
}
QPushButton:hover { background-color: #0f1724; }
QPushButton:pressed { background-color: #0b1220; }
]]></string>
    </property>

    <layout class="QVBoxLayout" name="verticalLayout_main">
      <property name="spacing"><number>6</number></property>

      <!-- TOP TOOLBAR -->
      <item>
        <widget class="QFrame" name="frame_top_toolbar">
          <property name="frameShape"><enum>QFrame::NoFrame</enum></property>
          <layout class="QHBoxLayout" name="hbox_top_toolbar">
            <property name="spacing"><number>8</number></property>

            <item>
              <widget class="QPushButton" name="btn_pause">
                <property name="text"><string>일시정지</string></property>
              </widget>
            </item>

            <item>
              <widget class="QPushButton" name="btn_refresh">
                <property name="text"><string>새로고침</string></property>
              </widget>
            </item>

            <item>
              <widget class="QPushButton" name="btn_export_selected">
