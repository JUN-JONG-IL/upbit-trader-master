 <class>ClickHouseSettingsDialog</class>
 <widget class="QDialog" name="ClickHouseSettingsDialog">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>900</width>
    <height>700</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>ClickHouse 모니터링</string>
