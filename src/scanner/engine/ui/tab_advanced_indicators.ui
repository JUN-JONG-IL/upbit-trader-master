  <property name="styleSheet">
   <string notr="true">QGroupBox {
  border: 1px solid #d1d5db;
  border-radius: 4px;
  margin-top: 8px;
  padding: 12px;
  background: #f9fafb;
  color: #111111;
  font-weight: bold;
}
QGroupBox::title {
  subcontrol-origin: margin;
  subcontrol-position: top left;
  padding: 0 8px;
  color: #111111;
}
QLabel {
  color: #374151;
  padding: 2px;
}
QComboBox {
  border: 1px solid #d1d5db;
  border-radius: 4px;
  padding: 4px 8px;
  background: white;
  color: #111111;
}
QComboBox:hover {
  border-color: #3b82f6;
}
QComboBox QAbstractItemView {
  background: #ffffff;
  color: #111111;
  selection-background-color: #e8eefc;
  selection-color: #111111;
  border: 1px solid #d1d5db;
}
QCheckBox {
  color: #111111;
  padding: 4px;
}
QCheckBox:hover {
  color: #111111;
  background: #f3f4f6;
}
QCheckBox::indicator {
  width: 14px;
  height: 14px;
  border: 1px solid #d1d5db;
  background: white;
}
QCheckBox::indicator:checked {
  background: #3b82f6;
  border-color: #3b82f6;
}
QSpinBox, QDoubleSpinBox {
  border: 1px solid #d1d5db;
  border-radius: 4px;
  padding: 4px 8px;
  background: white;
  color: #111111;
}
QSpinBox:focus, QDoubleSpinBox:focus {
  border-color: #3b82f6;
}</string>
