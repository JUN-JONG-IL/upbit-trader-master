            </property>
            <property name="styleSheet">
             <string notr="true">color: #334155; font-size: 9pt; line-height: 1.6;</string>
            </property>
           </widget>
          </item>
         </layout>
        </widget>
       </item>
       <!-- 섹션 3: Kafka 특화 기능 -->
