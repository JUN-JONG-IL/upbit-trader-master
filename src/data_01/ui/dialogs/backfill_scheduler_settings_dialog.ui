          <property name="toolTip"><string>15분봉 최대 캔들 수. 최소 30,000(라이트) ~ 150,000+(헤비). 50,000개 = 약 520일 분량.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QSpinBox" name="spin_limit_15m">
          <property name="minimum"><number>5000</number></property>
          <property name="maximum"><number>1000000</number></property>
          <property name="value"><number>30000</number></property>
          <property name="singleStep"><number>5000</number></property>
          <property name="minimumWidth"><number>110</number></property>
          <property name="toolTip"><string>15분봉 최대 보관 캔들 수.
라이트: 30,000 (≈312일) / 밸런스: 50,000 / 헤비: 150,000</string></property>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
          <property name="sizeHint" stdset="0"><size><width>20</width><height>20</height></size></property>
         </spacer>
        </item>
        <item>
         <widget class="QLabel">
          <property name="text"><string>1h 최대:</string></property>
          <property name="minimumWidth"><number>80</number></property>
          <property name="toolTip"><string>1시간봉 최대 캔들 수. 최소 12,000(라이트) ~ 60,000+(헤비). 20,000개 = 약 833일 분량.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QSpinBox" name="spin_limit_1h">
          <property name="minimum"><number>1000</number></property>
          <property name="maximum"><number>500000</number></property>
          <property name="value"><number>12000</number></property>
          <property name="singleStep"><number>1000</number></property>
          <property name="minimumWidth"><number>110</number></property>
          <property name="toolTip"><string>1시간봉 최대 보관 캔들 수.
라이트: 12,000 (≈500일) / 밸런스: 20,000 / 헤비: 60,000</string></property>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
          <property name="sizeHint" stdset="0"><size><width>20</width><height>20</height></size></property>
         </spacer>
        </item>
       </layout>
      </item>

      <!-- 4h / 1d 행 -->
