      <!-- 안내 레이블 -->
      <item>
        <widget class="QLabel" name="label_volume_guide">
        <property name="text">
          <string>💡 이 값은 수집 설정(상세)에서만 변경할 수 있습니다. 값이 클수록 디스크 사용량과 초기 수집 시간이 증가합니다.</string>
         </property>
        <property name="wordWrap"><bool>true</bool></property>
        <property name="styleSheet"><string notr="true">color: #555; font-size: 9pt;</string></property>
       </widget>
      </item>

     </layout>
    </widget>
   </item>

   <!-- ===== 스케줄러 설정 그룹 ===== -->
   <item>
    <widget class="QGroupBox" name="groupBox_scheduler">
     <property name="title">
      <string>스케줄러 설정</string>
     </property>
     <layout class="QVBoxLayout" name="vLayout_scheduler">

      <!-- 자동 실행 ON/OFF + 주기 -->
      <item>
       <layout class="QHBoxLayout">
        <item>
         <widget class="QCheckBox" name="chk_auto_run">
          <property name="text"><string>자동 실행</string></property>
          <property name="toolTip"><string>활성화 시 지정된 주기로 Gap 탐지 및 백필을 자동 실행합니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QLabel">
          <property name="text"><string>실행 주기:</string></property>
          <property name="toolTip"><string>자동 백필 실행 간격입니다. 1분봉 갭 감지 정확도를 위해 5~10분 주기를 권장합니다.</string></property>
         </widget>
        </item>
        <item>
          <widget class="QComboBox" name="combo_interval">
           <item><property name="text"><string>1분</string></property></item>
           <item><property name="text"><string>5분</string></property></item>
           <item><property name="text"><string>10분</string></property></item>
           <item><property name="text"><string>30분</string></property></item>
           <item><property name="text"><string>60분</string></property></item>
          </widget>
         </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
          <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
         </spacer>
        </item>
       </layout>
      </item>

      <!-- 앱 시작 시 자동 시작 / 즉시 실행 옵션 -->
      <item>
       <layout class="QHBoxLayout">
        <item>
         <widget class="QCheckBox" name="chk_auto_start_on_launch">
          <property name="text"><string>앱 시작 시 자동 시작</string></property>
          <property name="toolTip"><string>앱을 시작할 때 자동 백필 모드를 자동으로 활성화합니다. 설정값이 저장되어 있어야 동작합니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chk_kickoff_on_enable">
          <property name="text"><string>ON 전환 시 즉시 1회 실행</string></property>
          <property name="checked"><bool>true</bool></property>
          <property name="toolTip"><string>자동 모드를 켤 때 첫 주기를 기다리지 않고 즉시 1회 Gap 탐지를 실행합니다. 최신 데이터 동기화에 권장됩니다.</string></property>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
          <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
         </spacer>
        </item>
       </layout>
      </item>

      <!-- 동시 실행 정책 -->
      <item>
       <layout class="QHBoxLayout">
        <item>
         <widget class="QLabel">
          <property name="text"><string>동시 실행 정책:</string></property>
          <property name="toolTip"><string>이전 백필이 아직 실행 중일 때 새 주기가 도래하면 어떻게 처리할지 결정합니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QComboBox" name="combo_concurrent_policy">
          <item><property name="text"><string>진행 중이면 스킵</string></property></item>
          <item><property name="text"><string>완료 후 즉시 재실행</string></property></item>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
          <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
         </spacer>
        </item>
       </layout>
      </item>

     </layout>
    </widget>
   </item>

   <!-- ===== 성능(고급) 패널 ===== -->
   <item>
    <widget class="QGroupBox" name="groupBox_performance">
     <property name="title">
      <string>⚡ 성능 (고급) — 백필 처리 속도 튜닝</string>
     </property>
     <property name="toolTip">
      <string>여기서 변경한 값은 다음 백필 사이클부터 즉시 반영됩니다. 하드코딩 없이 모든 성능 파라미터를 한 곳에서 관리합니다. (저장 위치: ui_settings.backfill_scheduler.performance)</string>
     </property>
     <layout class="QVBoxLayout">
      <item>
       <widget class="QLabel" name="label_perf_banner">
        <property name="text">
         <string>💡 백필이 너무 느리면 동시 처리 수와 사이클당 Gap 수를 늘리세요. 글로벌 레이트 리미터(9 req/s)가 외부 API 한도를 자동 보호하므로 동시성 상향이 안전합니다. 단, DB 부하가 커질 수 있으니 시스템 자원에 맞춰 조절하세요.</string>
        </property>
        <property name="wordWrap"><bool>true</bool></property>
        <property name="styleSheet">
         <string notr="true">background-color: #FFF8E1; color: #5D4037; padding: 6px; border: 1px solid #FFD54F; border-radius: 4px; font-size: 9pt;</string>
        </property>
       </widget>
      </item>
      <item>
       <layout class="QHBoxLayout">
        <item>
         <widget class="QLabel">
          <property name="text"><string>동시 처리 수:</string></property>
          <property name="minimumWidth"><number>140</number></property>
          <property name="toolTip"><string>한 사이클에서 동시에 처리할 Gap 개수 (asyncio.Semaphore 크기). 값이 클수록 빠르지만 CPU/네트워크 부하가 늘어납니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QSpinBox" name="spin_perf_max_concurrency">
          <property name="minimum"><number>1</number></property>
          <property name="maximum"><number>32</number></property>
          <property name="value"><number>12</number></property>
          <property name="suffix"><string> 개</string></property>
          <property name="minimumWidth"><number>110</number></property>
          <property name="toolTip"><string>권장: 8~16. 글로벌 레이트 리미터가 외부 호출률을 자동 직렬화하므로 큰 값도 안전합니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QLabel" name="label_perf_concurrency_hint">
          <property name="text"><string>(권장 8~16, 기본 12)</string></property>
          <property name="styleSheet"><string notr="true">color: #757575; font-size: 9pt;</string></property>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
          <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
         </spacer>
        </item>
       </layout>
      </item>
      <item>
       <layout class="QHBoxLayout">
        <item>
         <widget class="QLabel">
          <property name="text"><string>사이클당 최대 Gap 수:</string></property>
          <property name="minimumWidth"><number>140</number></property>
          <property name="toolTip"><string>한 백필 실행에서 처리할 최대 Gap 건수. 큰 값일수록 한 번에 더 많이 소화하지만 사이클 1회의 소요 시간이 길어집니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QSpinBox" name="spin_perf_max_gaps_per_cycle">
          <property name="minimum"><number>50</number></property>
          <property name="maximum"><number>2000</number></property>
          <property name="singleStep"><number>50</number></property>
          <property name="value"><number>200</number></property>
          <property name="suffix"><string> 건</string></property>
          <property name="minimumWidth"><number>110</number></property>
          <property name="toolTip"><string>권장: 200~500. 잔여 Gap 수가 매우 많을 때 (예: 4만건+) 큰 값을 사용하면 빠르게 따라잡을 수 있습니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QLabel" name="label_perf_gaps_hint">
          <property name="text"><string>(권장 200~500, 기본 200)</string></property>
          <property name="styleSheet"><string notr="true">color: #757575; font-size: 9pt;</string></property>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
          <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
         </spacer>
        </item>
       </layout>
      </item>
      <item>
       <layout class="QHBoxLayout">
        <item>
         <widget class="QLabel">
          <property name="text"><string>Gap당 최대 페이지:</string></property>
          <property name="minimumWidth"><number>140</number></property>
          <property name="toolTip"><string>큰 Gap 1건을 채울 때 Upbit REST 페이지(200캔들/페이지)를 몇 번까지 돌 것인지 한도. 매우 큰 Gap(예: 며칠치 1m)을 한 번에 메우려면 200 이상을 권장합니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QSpinBox" name="spin_perf_max_pages_per_gap">
          <property name="minimum"><number>10</number></property>
          <property name="maximum"><number>500</number></property>
          <property name="singleStep"><number>10</number></property>
          <property name="value"><number>100</number></property>
          <property name="suffix"><string> 페이지</string></property>
          <property name="minimumWidth"><number>110</number></property>
          <property name="toolTip"><string>1페이지 = 200캔들. 100페이지 = 20,000캔들 (= 1m 기준 약 14일). 1m 한 달치 백필이 자주 끊긴다면 200~300으로 올리세요.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QLabel" name="label_perf_pages_hint">
          <property name="text"><string>(1페이지 = 200캔들, 기본 100)</string></property>
          <property name="styleSheet"><string notr="true">color: #757575; font-size: 9pt;</string></property>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
          <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
         </spacer>
        </item>
       </layout>
      </item>
      <item>
       <layout class="QHBoxLayout">
        <item>
         <widget class="QLabel">
          <property name="text"><string>REST 동시 요청 수:</string></property>
          <property name="minimumWidth"><number>140</number></property>
          <property name="toolTip"><string>RestCandleCollector 가 동시에 띄우는 캔들 조회 태스크 수. 글로벌 레이트 리미터(아래 한도)가 외부 호출률을 자동 직렬화하므로 큰 값도 안전합니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QSpinBox" name="spin_perf_rest_max_concurrent">
          <property name="minimum"><number>1</number></property>
          <property name="maximum"><number>32</number></property>
          <property name="value"><number>8</number></property>
          <property name="suffix"><string> 개</string></property>
          <property name="minimumWidth"><number>110</number></property>
          <property name="toolTip"><string>권장: 8~16. 다중 심볼·다중 TF 동시 수집 시 큰 값이 빠릅니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QLabel" name="label_perf_rest_concurrent_hint">
          <property name="text"><string>(권장 8~16, 기본 8)</string></property>
          <property name="styleSheet"><string notr="true">color: #757575; font-size: 9pt;</string></property>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
          <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
         </spacer>
        </item>
       </layout>
      </item>
      <item>
       <layout class="QHBoxLayout">
        <item>
         <widget class="QLabel">
          <property name="text"><string>REST 초당 한도:</string></property>
          <property name="minimumWidth"><number>140</number></property>
          <property name="toolTip"><string>Upbit REST 의 초당 호출 한도(공식 10 req/s). 안전마진을 두기 위해 9 권장. 10 으로 올리면 가끔 429 발생 가능.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QSpinBox" name="spin_perf_rest_rate_per_second">
          <property name="minimum"><number>1</number></property>
          <property name="maximum"><number>10</number></property>
          <property name="value"><number>9</number></property>
          <property name="suffix"><string> req/s</string></property>
          <property name="minimumWidth"><number>110</number></property>
          <property name="toolTip"><string>Upbit 한도: 10 req/s. 권장 9 (-1 안전마진).</string></property>
         </widget>
        </item>
        <item>
         <widget class="QLabel" name="label_perf_rps_hint">
          <property name="text"><string>(Upbit 한도 10, 권장 9)</string></property>
          <property name="styleSheet"><string notr="true">color: #757575; font-size: 9pt;</string></property>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
          <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
         </spacer>
        </item>
       </layout>
      </item>
      <item>
       <layout class="QHBoxLayout">
        <item>
         <widget class="QLabel">
          <property name="text"><string>REST 분당 한도:</string></property>
          <property name="minimumWidth"><number>140</number></property>
          <property name="toolTip"><string>Upbit REST 의 분당 호출 한도(공식 600 req/min). 안전마진을 두기 위해 550 권장.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QSpinBox" name="spin_perf_rest_rate_per_minute">
          <property name="minimum"><number>10</number></property>
          <property name="maximum"><number>600</number></property>
          <property name="singleStep"><number>10</number></property>
          <property name="value"><number>550</number></property>
          <property name="suffix"><string> req/min</string></property>
          <property name="minimumWidth"><number>110</number></property>
          <property name="toolTip"><string>Upbit 한도: 600 req/min. 권장 550 (-50 안전마진).</string></property>
         </widget>
        </item>
        <item>
         <widget class="QLabel" name="label_perf_rpm_hint">
          <property name="text"><string>(Upbit 한도 600, 권장 550)</string></property>
          <property name="styleSheet"><string notr="true">color: #757575; font-size: 9pt;</string></property>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
