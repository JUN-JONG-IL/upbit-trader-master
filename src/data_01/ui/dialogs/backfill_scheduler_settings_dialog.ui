<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>BackfillSchedulerSettingsDialog</class>
 <widget class="QDialog" name="BackfillSchedulerSettingsDialog">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>740</width>
    <height>860</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>백필 / 스케줄러 설정</string>
  </property>
  <layout class="QVBoxLayout" name="vLayout_root">

   <!-- ===== 역할 안내 헤더 ===== -->
   <item>
    <widget class="QLabel" name="label_role_header">
      <property name="text">
       <string>【 백필 / 스케줄러 실행 설정 】 백필 기간 · 대상 심볼 · 배치/재시도 · 자동 실행 주기를 설정합니다.
※ 수집 타임프레임/최대 캔들 수/압축/보관 정책은 '수집 설정(상세)'에서만 편집합니다.</string>
      </property>
     <property name="wordWrap"><bool>true</bool></property>
     <property name="styleSheet">
      <string notr="true">background-color: #E8EAF6; color: #283593; font-size: 9pt; font-weight: bold; padding: 6px; border-radius: 4px;</string>
     </property>
      <property name="toolTip">
       <string>【 이 창의 담당 범위 】
• 백필 실행 기간 (7일/30일/90일/사용자 지정)
• 대상 심볼 (전체 / 선택 심볼)
• 스케줄러 자동실행 주기 및 상태

【 '수집 설정(상세)' 창의 담당 범위 — 이 창에서는 변경 불가 】
• 실시간 수집할 전역 타임프레임
• 타임프레임별 최대 캔들 수 한도 (라이트/밸런스/헤비)
• TimescaleDB 압축 시작 시점
• 데이터 보관 기간 (자동 삭제 정책)
• WebSocket 구독 심볼 수
• 수집 정책 프리셋</string>
      </property>
    </widget>
   </item>

   <!-- ===== 백필 설정 그룹 ===== -->
   <item>
    <widget class="QGroupBox" name="groupBox_backfill">
     <property name="title">
      <string>백필 설정</string>
     </property>
     <layout class="QVBoxLayout" name="vLayout_backfill">

      <!-- 기간 프리셋 -->
      <item>
       <layout class="QHBoxLayout">
        <item>
         <widget class="QLabel">
          <property name="text"><string>기간 프리셋:</string></property>
          <property name="toolTip"><string>수집할 과거 데이터의 기간 범위를 빠르게 설정합니다. 기간이 길수록 초기 수집에 시간이 오래 걸립니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="btn_preset_7d">
          <property name="text"><string>최근 7일</string></property>
          <property name="checkable"><bool>true</bool></property>
          <property name="toolTip"><string>최근 7일치 캔들 데이터를 백필합니다. 빠른 초기화에 적합하지만 지표 안정성은 낮습니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="btn_preset_30d">
          <property name="text"><string>최근 30일</string></property>
          <property name="checkable"><bool>true</bool></property>
          <property name="toolTip"><string>최근 30일치 캔들 데이터를 백필합니다. 단기 지표(RSI/MACD) 안정화에 권장됩니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="btn_preset_90d">
          <property name="text"><string>최근 90일</string></property>
          <property name="checkable"><bool>true</bool></property>
          <property name="toolTip"><string>최근 90일치 캔들 데이터를 백필합니다. 중기 추세 분석에 적합합니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="btn_preset_custom">
          <property name="text"><string>사용자 지정</string></property>
          <property name="checkable"><bool>true</bool></property>
          <property name="toolTip"><string>시작일과 종료일을 직접 지정합니다.</string></property>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
          <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
         </spacer>
        </item>
       </layout>
      </item>

      <!-- 시작일 / 종료일 -->
      <item>
       <layout class="QHBoxLayout">
        <item>
         <widget class="QLabel">
          <property name="text"><string>시작일:</string></property>
          <property name="minimumWidth"><number>60</number></property>
          <property name="toolTip"><string>백필 시작 날짜 (포함). 기간 프리셋 선택 시 자동 설정됩니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QDateEdit" name="date_start">
          <property name="calendarPopup"><bool>true</bool></property>
          <property name="displayFormat"><string>yyyy-MM-dd</string></property>
          <property name="minimumWidth"><number>130</number></property>
         </widget>
        </item>
        <item>
         <widget class="QLabel">
          <property name="text"><string>종료일:</string></property>
          <property name="minimumWidth"><number>60</number></property>
          <property name="toolTip"><string>백필 종료 날짜 (포함). 기본값은 오늘입니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QDateEdit" name="date_end">
          <property name="calendarPopup"><bool>true</bool></property>
          <property name="displayFormat"><string>yyyy-MM-dd</string></property>
          <property name="minimumWidth"><number>130</number></property>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
          <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
         </spacer>
        </item>
       </layout>
      </item>

      <!-- 대상 타임프레임 -->
      <item>
        <widget class="QLabel" name="label_tf_note">
        <property name="text">
          <string>※ 수집 타임프레임/최대 캔들 수는 '수집 설정(상세)'에서 관리합니다. 여기서는 실행 시 적용될 값을 읽기 전용으로 표시합니다.</string>
        </property>
        <property name="wordWrap"><bool>true</bool></property>
        <property name="styleSheet"><string notr="true">color: #5D4037; font-size: 8pt; font-style: italic;</string></property>
       </widget>
      </item>
      <item>
       <layout class="QHBoxLayout">
        <item>
          <widget class="QLabel">
           <property name="text"><string>수집 타임프레임(읽기 전용):</string></property>
           <property name="toolTip"><string>'수집 설정(상세)'에서 저장된 전역 수집 타임프레임을 표시합니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chk_bf_tf_1m">
          <property name="text"><string>1m</string></property>
          <property name="checked"><bool>true</bool></property>
          <property name="toolTip"><string>1분봉. 데이터 양이 가장 많습니다. 스캘핑·고빈도 전략에 필요합니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chk_bf_tf_5m">
          <property name="text"><string>5m</string></property>
          <property name="checked"><bool>true</bool></property>
          <property name="toolTip"><string>5분봉. 단기 스윙·모멘텀 전략에 활용됩니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chk_bf_tf_15m">
          <property name="text"><string>15m</string></property>
          <property name="toolTip"><string>15분봉. RSI/MACD 지표 신뢰도 확보에 적합합니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chk_bf_tf_1h">
          <property name="text"><string>1h</string></property>
          <property name="checked"><bool>true</bool></property>
          <property name="toolTip"><string>1시간봉. 중기 추세 분석의 기본 타임프레임입니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chk_bf_tf_4h">
          <property name="text"><string>4h</string></property>
          <property name="toolTip"><string>4시간봉. 스윙 트레이딩 및 레짐 판별에 활용됩니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="chk_bf_tf_1d">
          <property name="text"><string>1d</string></property>
          <property name="toolTip"><string>일봉. AI/ML 학습, EMA200, 장기 추세 분석에 필수입니다. 최소 500개 이상 확보를 권장합니다.</string></property>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
          <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
         </spacer>
        </item>
       </layout>
      </item>

      <!-- 대상 심볼 범위 -->
      <item>
       <layout class="QHBoxLayout">
        <item>
          <widget class="QLabel">
           <property name="text"><string>대상 심볼:</string></property>
           <property name="toolTip"><string>백필할 심볼 범위를 선택합니다.
• 전체 심볼: 업비트에 상장된 모든 심볼을 대상으로 합니다. (시간 많이 소요)
• 선택 심볼: 스캐너 탭 또는 AI/ML 탭에서
   현재 선택·활성화된 심볼만 대상으로 합니다. (빠르고 권장)

※ '선택 심볼 (스마트 스캐너 + AI/ML 선택 결과)'을 사용하려면
  스캐너 탭 또는 AI/ML 탭에서 심볼이 선택되어 있어야 합니다.</string>
          </property>
         </widget>
        </item>
        <item>
          <widget class="QComboBox" name="combo_symbol_range">
           <item><property name="text"><string>전체 심볼</string></property></item>
           <item><property name="text"><string>선택 심볼 (스마트 스캐너 + AI/ML 선택 결과)</string></property></item>
          </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
          <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
         </spacer>
        </item>
       </layout>
      </item>

      <!-- 배치 크기 / 재시도 -->
      <item>
       <layout class="QHBoxLayout">
        <item>
         <widget class="QLabel">
          <property name="text"><string>배치 크기:</string></property>
          <property name="toolTip"><string>한 번에 API에서 가져올 캔들 수입니다. 너무 크면 API Rate Limit에 걸릴 수 있습니다. 권장: 100~500건.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QSpinBox" name="spin_batch_size">
          <property name="minimum"><number>1</number></property>
          <property name="maximum"><number>10000</number></property>
          <property name="value"><number>200</number></property>
          <property name="singleStep"><number>50</number></property>
          <property name="minimumWidth"><number>80</number></property>
          <property name="toolTip"><string>1회 API 요청당 캔들 수. 업비트 기본 제한은 200건/요청입니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QLabel">
          <property name="text"><string>건/배치</string></property>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
          <property name="sizeHint" stdset="0"><size><width>20</width><height>20</height></size></property>
         </spacer>
        </item>
        <item>
         <widget class="QLabel">
          <property name="text"><string>재시도 횟수:</string></property>
          <property name="toolTip"><string>API 오류 또는 네트워크 실패 시 재시도할 횟수입니다. 권장: 2~5회.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QSpinBox" name="spin_retry_count">
          <property name="minimum"><number>0</number></property>
          <property name="maximum"><number>10</number></property>
          <property name="value"><number>3</number></property>
          <property name="minimumWidth"><number>60</number></property>
          <property name="toolTip"><string>0이면 재시도 없음. 불안정한 환경에서는 3~5를 권장합니다.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QLabel">
          <property name="text"><string>재시도 간격:</string></property>
          <property name="toolTip"><string>재시도 전 대기 시간입니다. 너무 짧으면 API 차단 위험이 있습니다. 권장: 5~30초.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QSpinBox" name="spin_retry_interval">
          <property name="minimum"><number>1</number></property>
          <property name="maximum"><number>300</number></property>
          <property name="value"><number>10</number></property>
          <property name="suffix"><string> 초</string></property>
          <property name="minimumWidth"><number>70</number></property>
          <property name="toolTip"><string>API 오류 후 재시도까지 대기하는 초 수입니다.</string></property>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
          <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
         </spacer>
        </item>
       </layout>
      </item>

     </layout>
    </widget>
   </item>

   <!-- ===== 데이터 용량 프리셋 그룹 ===== -->
   <item>
    <widget class="QGroupBox" name="groupBox_data_preset">
     <property name="title">
       <string>데이터 용량 프리셋 요약(읽기 전용)</string>
      </property>
     <property name="toolTip">
       <string>【 읽기 전용 요약 】
수집 설정(상세)의 단일 편집 소스(SSOT)에서 저장된 타임프레임별 최대 캔들 수를 표시합니다.

• 🟢 라이트: 저사양 PC / 기본 지표 운용 최소 구성 (기본값)
• 🔵 밸런스: 일반 트레이딩 / 멀티 지표 / 스캐너 표준 구성
• 🔴 헤비: AI/ML 학습 / 고정밀 분석 / 대용량 구성

※ 편집은 '수집 설정(상세)'에서만 가능합니다.</string>
      </property>
     <layout class="QVBoxLayout" name="vLayout_data_preset">

      <!-- 프리셋 선택 버튼 -->
      <item>
       <layout class="QHBoxLayout">
        <item>
          <widget class="QLabel">
           <property name="text"><string>프리셋(읽기 전용):</string></property>
           <property name="toolTip"><string>수집 설정(상세)에서 선택된 프리셋입니다.</string></property>
          </widget>
         </item>
         <item>
          <widget class="QComboBox" name="combo_volume_preset">
           <item><property name="text"><string>🟢 라이트</string></property></item>
           <item><property name="text"><string>🔵 밸런스</string></property></item>
           <item><property name="text"><string>🔴 헤비</string></property></item>
          </widget>
         </item>
        <item>
         <widget class="QPushButton" name="btn_volume_preset_light">
          <property name="text"><string>🟢 라이트</string></property>
          <property name="toolTip"><string>저사양·저용량용 최소 구성.
1m: 150,000 | 5m: 50,000 | 15m: 30,000
1h: 12,000  | 4h: 5,000  | 1d: 500
적합: 기본 지표(RSI/MACD/BB) 운용, 단순 차트 표시</string></property>
          <property name="styleSheet"><string notr="true">background-color: #E8F5E9; color: #2E7D32; font-weight: bold;</string></property>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="btn_volume_preset_balance">
          <property name="text"><string>🔵 밸런스</string></property>
          <property name="toolTip"><string>기본 권장 구성. 지표+스캐너+차트 균형.
1m: 300,000 | 5m: 100,000 | 15m: 50,000
1h: 20,000  | 4h: 10,000  | 1d: 1,000
적합: 일반 트레이딩, 멀티 지표, 스캐너</string></property>
          <property name="styleSheet"><string notr="true">background-color: #E3F2FD; color: #1565C0; font-weight: bold;</string></property>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="btn_volume_preset_heavy">
          <property name="text"><string>🔴 헤비</string></property>
          <property name="toolTip"><string>고급·AI 확장 구성. 최대 성능.
1m: 1,000,000 | 5m: 300,000 | 15m: 150,000
1h: 60,000    | 4h: 30,000  | 1d: 3,000
적합: AI/ML 학습, 감성분석, 워크포워드 검증</string></property>
          <property name="styleSheet"><string notr="true">background-color: #FCE4EC; color: #B71C1C; font-weight: bold;</string></property>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
          <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
         </spacer>
        </item>
       </layout>
      </item>

      <!-- 1m / 5m 행 -->
      <item>
       <layout class="QHBoxLayout">
        <item>
         <widget class="QLabel">
          <property name="text"><string>1m 최대:</string></property>
          <property name="minimumWidth"><number>80</number></property>
          <property name="toolTip"><string>1분봉 최대 캔들 수. 최소 150,000(라이트) ~ 1,000,000+(헤비). 1,000,000개 = 약 694일 분량.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QSpinBox" name="spin_limit_1m">
          <property name="minimum"><number>10000</number></property>
          <property name="maximum"><number>5000000</number></property>
          <property name="value"><number>150000</number></property>
          <property name="singleStep"><number>50000</number></property>
          <property name="minimumWidth"><number>110</number></property>
          <property name="toolTip"><string>1분봉 최대 보관 캔들 수.
라이트: 150,000 (≈104일) / 밸런스: 300,000 / 헤비: 1,000,000
값이 클수록 더 많은 디스크 공간이 필요합니다.</string></property>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
          <property name="sizeHint" stdset="0"><size><width>20</width><height>20</height></size></property>
         </spacer>
        </item>
        <item>
         <widget class="QLabel">
          <property name="text"><string>5m 최대:</string></property>
          <property name="minimumWidth"><number>80</number></property>
          <property name="toolTip"><string>5분봉 최대 캔들 수. 최소 50,000(라이트) ~ 300,000+(헤비). 100,000개 = 약 347일 분량.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QSpinBox" name="spin_limit_5m">
          <property name="minimum"><number>5000</number></property>
          <property name="maximum"><number>2000000</number></property>
          <property name="value"><number>50000</number></property>
          <property name="singleStep"><number>10000</number></property>
          <property name="minimumWidth"><number>110</number></property>
          <property name="toolTip"><string>5분봉 최대 보관 캔들 수.
라이트: 50,000 (≈173일) / 밸런스: 100,000 / 헤비: 300,000</string></property>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
