         <widget class="QLabel">
          <property name="text"><string>4h 최대:</string></property>
          <property name="minimumWidth"><number>80</number></property>
          <property name="toolTip"><string>4시간봉 최대 캔들 수. 최소 5,000(라이트) ~ 30,000+(헤비). 10,000개 = 약 1,666일 분량.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QSpinBox" name="spin_limit_4h">
          <property name="minimum"><number>500</number></property>
          <property name="maximum"><number>200000</number></property>
          <property name="value"><number>5000</number></property>
          <property name="singleStep"><number>500</number></property>
          <property name="minimumWidth"><number>110</number></property>
          <property name="toolTip"><string>4시간봉 최대 보관 캔들 수.
라이트: 5,000 (≈833일) / 밸런스: 10,000 / 헤비: 30,000</string></property>
         </widget>
        </item>
        <item>
         <spacer>
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
          <property name="sizeHint" stdset="0"><size><width>20</width><height>20</height></size></property>
         </spacer>
        </item>
        <item>
         <widget class="QLabel">
          <property name="text"><string>1d 최대:</string></property>
          <property name="minimumWidth"><number>80</number></property>
          <property name="toolTip"><string>일봉 최대 캔들 수. 최소 500(라이트) ~ 3,000+(헤비). 1,000개 = 약 2.7년 분량. AI/ML은 최소 1,000개 권장.</string></property>
         </widget>
        </item>
        <item>
         <widget class="QSpinBox" name="spin_limit_1d">
          <property name="minimum"><number>100</number></property>
          <property name="maximum"><number>10000</number></property>
