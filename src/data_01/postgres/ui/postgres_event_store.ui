          </widget>
         </item>
         <item>
          <widget class="QPushButton" name="btnNextPage">
           <property name="text"><string>다음 ▶</string></property>
          </widget>
         </item>
         <item>
          <widget class="QPushButton" name="btnExportCSV">
           <property name="text"><string>📤 CSV</string></property>
          </widget>
         </item>
        </layout>
       </item>
      </layout>
     </widget>

     <!-- ========================================== -->
     <!-- Tab: ⚙️ DB 상세 정보 -->
     <!-- ========================================== -->
     <widget class="QWidget" name="tabDBInfo">
