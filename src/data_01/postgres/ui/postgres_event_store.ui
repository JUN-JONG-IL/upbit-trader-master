     <!-- ===== 탭 2: 이벤트 스토어 ===== -->
     <widget class="QWidget" name="tabEventStore">
      <attribute name="title">
       <string>📝 이벤트 스토어</string>
      </attribute>
      <layout class="QVBoxLayout" name="verticalLayout_events">
       <property name="spacing">
        <number>6</number>
       </property>
       <!-- 필터 행 -->
       <item>
        <widget class="QGroupBox" name="groupEventFilter">
         <property name="title">
          <string>필터</string>
         </property>
         <layout class="QHBoxLayout" name="horizontalLayout_eventFilter">
          <item>
           <widget class="QLabel">
            <property name="text"><string>이벤트 타입:</string></property>
           </widget>
          </item>
          <item>
           <widget class="QComboBox" name="comboEventTypeFilter">
            <item><property name="text"><string>전체</string></property></item>
            <item><property name="text"><string>OrderCreated</string></property></item>
            <item><property name="text"><string>OrderFilled</string></property></item>
            <item><property name="text"><string>TradeExecuted</string></property></item>
           </widget>
          </item>
          <item>
           <widget class="QLabel">
            <property name="text"><string>Aggregate ID:</string></property>
           </widget>
          </item>
          <item>
           <widget class="QLineEdit" name="lineAggregateFilter">
            <property name="placeholderText">
             <string>aggregate_id 검색...</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QLabel">
            <property name="text"><string>시작일:</string></property>
           </widget>
          </item>
          <item>
           <widget class="QDateEdit" name="dateStartFilter">
            <property name="calendarPopup">
             <bool>true</bool>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QLabel">
            <property name="text"><string>종료일:</string></property>
           </widget>
          </item>
          <item>
           <widget class="QDateEdit" name="dateEndFilter">
            <property name="calendarPopup">
             <bool>true</bool>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="btnFilterEvents">
            <property name="text"><string>조회</string></property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="btnReplayEvent">
            <property name="text"><string>이벤트 재생</string></property>
           </widget>
          </item>
         </layout>
        </widget>
       </item>
       <!-- 이벤트 테이블 -->
       <item>
        <widget class="QTableWidget" name="tableEvents">
         <property name="columnCount">
          <number>5</number>
         </property>
         <property name="selectionBehavior">
          <enum>QAbstractItemView::SelectRows</enum>
         </property>
         <property name="alternatingRowColors">
          <bool>true</bool>
         </property>
         <attribute name="horizontalHeaderLabel">
          <string>event_id</string>
         </attribute>
         <attribute name="horizontalHeaderLabel">
          <string>event_type</string>
         </attribute>
         <attribute name="horizontalHeaderLabel">
          <string>aggregate_id</string>
         </attribute>
         <attribute name="horizontalHeaderLabel">
          <string>timestamp</string>
         </attribute>
         <attribute name="horizontalHeaderLabel">
          <string>payload (미리보기)</string>
         </attribute>
         <column>
          <property name="text"><string>event_id</string></property>
         </column>
         <column>
          <property name="text"><string>event_type</string></property>
         </column>
         <column>
          <property name="text"><string>aggregate_id</string></property>
         </column>
         <column>
          <property name="text"><string>timestamp</string></property>
         </column>
         <column>
          <property name="text"><string>payload (미리보기)</string></property>
         </column>
        </widget>
       </item>
      </layout>
     </widget>

     <!-- ===== 탭 3: CQRS Write ===== -->
     <widget class="QWidget" name="tabCqrsWrite">
      <attribute name="title">
       <string>✍️ CQRS Write</string>
      </attribute>
      <layout class="QVBoxLayout" name="verticalLayout_write">
       <property name="spacing">
        <number>8</number>
       </property>
       <item>
        <widget class="QGroupBox" name="groupPublishEvent">
         <property name="title">
          <string>이벤트 발행</string>
         </property>
         <layout class="QGridLayout" name="gridLayout_publish">
          <item row="0" column="0">
           <widget class="QLabel">
            <property name="text"><string>이벤트 타입:</string></property>
           </widget>
          </item>
          <item row="0" column="1">
           <widget class="QComboBox" name="comboEventType">
            <item><property name="text"><string>OrderCreated</string></property></item>
            <item><property name="text"><string>OrderFilled</string></property></item>
            <item><property name="text"><string>TradeExecuted</string></property></item>
           </widget>
          </item>
          <item row="1" column="0">
           <widget class="QLabel">
            <property name="text"><string>Aggregate ID:</string></property>
           </widget>
          </item>
          <item row="1" column="1">
           <widget class="QLineEdit" name="lineAggregateId">
            <property name="placeholderText">
             <string>aggregate_id 입력...</string>
            </property>
           </widget>
          </item>
          <item row="2" column="0">
           <widget class="QLabel">
            <property name="text"><string>Payload (JSON):</string></property>
           </widget>
          </item>
          <item row="2" column="1">
           <widget class="QPlainTextEdit" name="textPayload">
            <property name="placeholderText">
             <string>{ "key": "value" }</string>
            </property>
           </widget>
          </item>
          <item row="3" column="0">
           <widget class="QLabel">
            <property name="text"><string>Metadata (JSON):</string></property>
           </widget>
          </item>
          <item row="3" column="1">
           <widget class="QPlainTextEdit" name="textMetadata">
            <property name="placeholderText">
             <string>{ "source": "ui" }</string>
            </property>
           </widget>
          </item>
          <item row="4" column="0" colspan="2">
           <layout class="QHBoxLayout" name="horizontalLayout_writeButtons">
            <item>
             <widget class="QPushButton" name="btnPublishEvent">
              <property name="text"><string>이벤트 발행</string></property>
             </widget>
            </item>
            <item>
             <widget class="QPushButton" name="btnGenerateTestEvent">
              <property name="text"><string>테스트 이벤트 생성</string></property>
             </widget>
            </item>
            <item>
             <spacer name="horizontalSpacer_write">
              <property name="orientation">
               <enum>Qt::Horizontal</enum>
              </property>
              <property name="sizeHint" stdset="0">
               <size>
                <width>40</width>
                <height>20</height>
               </size>
              </property>
             </spacer>
            </item>
           </layout>
          </item>
         </layout>
        </widget>
       </item>
       <item>
        <spacer name="verticalSpacer_write">
         <property name="orientation">
          <enum>Qt::Vertical</enum>
         </property>
         <property name="sizeHint" stdset="0">
          <size>
           <width>20</width>
           <height>40</height>
          </size>
         </property>
        </spacer>
       </item>
      </layout>
     </widget>

