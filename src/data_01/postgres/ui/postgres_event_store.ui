          <item row="3" column="1">
           <widget class="QLabel" name="labelMemory">
            <property name="text"><string>-</string></property>
           </widget>
          </item>
         </layout>
        </widget>
       </item>
       <item>
        <widget class="QGroupBox" name="groupPerformance">
         <property name="title"><string>성능 지표</string></property>
         <layout class="QGridLayout" name="gridLayout_perf">
          <item row="0" column="0">
