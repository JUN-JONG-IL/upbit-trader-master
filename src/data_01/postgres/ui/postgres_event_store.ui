      </layout>
     </widget>
    </widget>
   </item>
      <widget class="QWidget" name="tabDataDelete">
       <attribute name="title"><string>🗑️ 데이터 삭제</string></attribute>
       <layout class="QVBoxLayout" name="vl_pgDelete">
