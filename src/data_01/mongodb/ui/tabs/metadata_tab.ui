      </property>
     </column>
     <column>
      <property name="text">
       <string>상태</string>
      </property>
     </column>
     <column>
      <property name="text">
       <string>최신 업데이트</string>
      </property>
     </column>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox" name="priorityGroup">
     <property name="title">
      <string>🎯 우선순위 설정</string>
     </property>
     <layout class="QVBoxLayout" name="vLayout_priority">
      <property name="spacing">
       <number>8</number>
      </property>
      <!-- 거래량 기반 -->
      <item>
       <widget class="QCheckBox" name="chkVolumeWeight">
        <property name="text">
         <string>거래량 기반 (1~10점)</string>
        </property>
        <property name="checked">
         <bool>true</bool>
        </property>
       </widget>
      </item>
      <item>
       <layout class="QHBoxLayout" name="hLayout_volume_slider">
        <item>
         <widget class="QLabel" name="lblVolumeWeightValue">
          <property name="text">
           <string>거래량 가중치: 5</string>
          </property>
          <property name="minimumWidth">
           <number>120</number>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QSlider" name="sliderVolumeWeight">
          <property name="orientation">
           <enum>Qt::Horizontal</enum>
          </property>
          <property name="minimum">
           <number>1</number>
          </property>
          <property name="maximum">
           <number>10</number>
          </property>
          <property name="value">
           <number>5</number>
          </property>
          <property name="tickPosition">
           <enum>QSlider::TicksBelow</enum>
          </property>
         </widget>
        </item>
       </layout>
      </item>
      <!-- 즐겨찾기 우선 -->
      <item>
       <widget class="QCheckBox" name="chkFavoritePriority">
        <property name="text">
         <string>즐겨찾기 종목 우선 (+2점)</string>
        </property>
       </widget>
      </item>
      <!-- 수동 점수 -->
      <item>
       <widget class="QCheckBox" name="chkManualScore">
        <property name="text">
         <string>수동 점수 설정 (종목별 커스텀)</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QTableWidget" name="tableManualScores">
        <property name="maximumHeight">
         <number>120</number>
        </property>
        <property name="columnCount">
         <number>3</number>
        </property>
        <attribute name="horizontalHeaderStretchLastSection">
         <bool>true</bool>
        </attribute>
        <column>
         <property name="text">
          <string>심볼</string>
         </property>
        </column>
        <column>
         <property name="text">
          <string>점수</string>
         </property>
        </column>
        <column>
         <property name="text">
          <string>이유</string>
         </property>
        </column>
       </widget>
      </item>
      <!-- AND/OR 조건 조합 -->
      <item>
       <widget class="QGroupBox" name="conditionGroup">
        <property name="title">
         <string>조건 조합</string>
        </property>
        <layout class="QVBoxLayout" name="vLayout_condition">
         <item>
          <layout class="QHBoxLayout" name="hLayout_radio">
           <item>
            <widget class="QRadioButton" name="radioAnd">
             <property name="text">
              <string>AND (모든 조건 만족)</string>
             </property>
             <property name="checked">
              <bool>true</bool>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QRadioButton" name="radioOr">
             <property name="text">
              <string>OR (하나 이상 만족)</string>
             </property>
            </widget>
           </item>
          </layout>
         </item>
         <item>
          <widget class="QLineEdit" name="txtCustomCondition">
           <property name="placeholderText">
            <string>(거래량 &gt; 1000 AND 즐겨찾기) OR (수동점수 &gt;= 8)</string>
           </property>
          </widget>
         </item>
        </layout>
       </widget>
      </item>
      <!-- 점수 계산식 미리보기 -->
      <item>
       <widget class="QLabel" name="lblFormulaPreview">
        <property name="text">
         <string>💡 점수 계산식: score = log10(volume) × 5 + favorite_bonus + manual_score</string>
        </property>
        <property name="wordWrap">
         <bool>true</bool>
        </property>
        <property name="styleSheet">
         <string notr="true">background-color: #E8F5E9; padding: 8px; border-radius: 4px; color: #1B5E20;</string>
        </property>
       </widget>
      </item>
      <!-- 버튼 -->
      <item>
       <layout class="QHBoxLayout" name="hLayout_priority_buttons">
        <item>
         <spacer name="horizontalSpacer_priority">
          <property name="orientation">
           <enum>Qt::Horizontal</enum>
          </property>
          <property name="sizeHint" stdset="0">
           <size>
            <width>40</width>
            <height>20</height>
           </size>
          </property>
         </spacer>
        </item>
        <item>
         <widget class="QPushButton" name="btnSavePriority">
          <property name="text">
           <string>💾 저장</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="btnResetPriority">
          <property name="text">
           <string>🔄 초기화</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="btnTestPriority">
          <property name="text">
           <string>🧪 테스트</string>
          </property>
         </widget>
        </item>
       </layout>
      </item>
     </layout>
    </widget>
   </item>
  </layout>
 </widget>
