  <property name="styleSheet">
   <string notr="true">
    QDialog { background-color: #31363b; color: #eff0f1; }
    QTabWidget::pane { border: 1px solid #4a4f54; background-color: #31363b; }
    QTabBar::tab { background-color: #2a2e32; color: #eff0f1; padding: 6px 14px; border: 1px solid #4a4f54; border-bottom: none; border-radius: 4px 4px 0 0; }
    QTabBar::tab:selected { background-color: #31363b; color: #3daee9; font-weight: bold; }
    QTabBar::tab:hover { background-color: #3a3f44; }
    QTableWidget { background-color: #232629; color: #eff0f1; gridline-color: #4a4f54; border: 1px solid #4a4f54; selection-background-color: #3daee9; }
    QTableWidget::item { padding: 4px; }
    QHeaderView::section { background-color: #2a2e32; color: #eff0f1; padding: 4px; border: 1px solid #4a4f54; font-weight: bold; }
    QLabel { color: #eff0f1; }
    QPushButton { background-color: #3daee9; color: #ffffff; border-radius: 4px; padding: 5px 16px; border: none; }
    QPushButton:hover { background-color: #4dc0f5; }
    QPushButton:pressed { background-color: #2a9bd3; }
    QProgressBar { background-color: #232629; border: 1px solid #4a4f54; border-radius: 3px; text-align: center; color: #eff0f1; }
    QProgressBar::chunk { background-color: #3daee9; border-radius: 2px; }
    QComboBox { background-color: #232629; color: #eff0f1; border: 1px solid #4a4f54; border-radius: 3px; padding: 3px 8px; }
    QComboBox QAbstractItemView { background-color: #232629; color: #eff0f1; selection-background-color: #3daee9; }
    QSpinBox { background-color: #232629; color: #eff0f1; border: 1px solid #4a4f54; border-radius: 3px; padding: 3px 8px; }
    QPlainTextEdit { background-color: #232629; color: #eff0f1; border: 1px solid #4a4f54; border-radius: 3px; }
    QScrollBar:vertical { background-color: #232629; width: 10px; }
    QScrollBar::handle:vertical { background-color: #4a4f54; border-radius: 5px; }
   </string>
  </property>
