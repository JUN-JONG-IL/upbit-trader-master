            </widget>
           </item>
           <item>
            <widget class="QRadioButton" name="radioAnomalyAutoencoder">
             <property name="text">
              <string>Autoencoder (딥러닝 기반)</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QRadioButton" name="radioAnomalyIsolationForest">
             <property name="text">
              <string>Isolation Forest (빠르고 효율적, 추천)</string>
