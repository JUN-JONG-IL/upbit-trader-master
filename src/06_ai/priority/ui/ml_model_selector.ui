           </item>
           <item>
            <widget class="QRadioButton" name="radioAdaptiveHybrid">
             <property name="text">
              <string>하이브리드 (심볼 + 변동성)</string>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
       </layout>
      </widget>
      <!-- ===== TAB 3: 이상치 감지 ===== -->
      <widget class="QWidget" name="tabAnomaly">
       <attribute name="title">
        <string>이상치 감지</string>
