          </layout>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="grpAnomalyThreshold">
          <property name="title">
           <string>임계값 설정</string>
          </property>
          <layout class="QVBoxLayout" name="vboxAnomalyThreshold">
           <item>
            <widget class="QLabel" name="lblAnomalyThreshold">
             <property name="text">
              <string>임계값: 0.95 (95%)</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QSlider" name="sliderAnomalyThreshold">
             <property name="orientation">
              <enum>Qt::Horizontal</enum>
             </property>
             <property name="minimum">
              <number>50</number>
             </property>
             <property name="maximum">
              <number>99</number>
             </property>
             <property name="value">
              <number>95</number>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="btnTestAnomaly">
          <property name="text">
           <string>이상치 감지 테스트</string>
          </property>
         </widget>
        </item>
       </layout>
      </widget>
      <!-- ===== TAB 4: Drift 모니터링 ===== -->
      <widget class="QWidget" name="tabDrift">
