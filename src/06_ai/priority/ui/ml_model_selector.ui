             <property name="maximum">
              <number>86400</number>
             </property>
             <property name="value">
              <number>3600</number>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="btnTestDrift">
          <property name="text">
           <string>Drift 체크 테스트</string>
          </property>
