    <item>
     <widget class="QTabWidget" name="tabWidget">
      <!-- ===== TAB 1: Gap 예측 모델 ===== -->
      <widget class="QWidget" name="tabGap">
       <attribute name="title">
        <string>Gap 예측 모델</string>
       </attribute>
       <layout class="QVBoxLayout" name="vboxGap">
        <item>
         <widget class="QGroupBox" name="grpGapModel">
          <property name="title">
           <string>Gap 예측 모델 선택</string>
          </property>
          <layout class="QVBoxLayout" name="vboxGapModel">
           <item>
            <widget class="QCheckBox" name="chkGapEnabled">
             <property name="text">
              <string>Gap 예측 활성화</string>
             </property>
             <property name="checked">
              <bool>true</bool>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QRadioButton" name="radioGapXGBoost">
             <property name="text">
              <string>XGBoost (기본)</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QRadioButton" name="radioGapLightGBM">
             <property name="text">
              <string>LightGBM (빠르고 메모리 효율적, 추천)</string>
             </property>
             <property name="checked">
              <bool>true</bool>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QRadioButton" name="radioGapCatBoost">
             <property name="text">
              <string>CatBoost (범주형 데이터 강점)</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QRadioButton" name="radioGapProphet">
             <property name="text">
              <string>Prophet (Facebook, 시계열 특화)</string>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="btnTestGap">
          <property name="text">
           <string>Gap 예측 테스트</string>
          </property>
         </widget>
        </item>
       </layout>
      </widget>
      <!-- ===== TAB 2: Adaptive TimeFrame ===== -->
      <widget class="QWidget" name="tabAdaptive">
       <attribute name="title">
        <string>Adaptive TimeFrame</string>
       </attribute>
       <layout class="QVBoxLayout" name="vboxAdaptive">
        <item>
         <widget class="QGroupBox" name="grpAdaptiveTF">
          <property name="title">
           <string>Adaptive TimeFrame 설정</string>
          </property>
          <layout class="QVBoxLayout" name="vboxAdaptiveTF">
           <item>
            <widget class="QCheckBox" name="chkAdaptiveTF">
             <property name="text">
              <string>Adaptive TimeFrame 활성화</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QRadioButton" name="radioAdaptiveSymbol">
             <property name="text">
              <string>심볼별 최적 타임프레임 자동 선택</string>
             </property>
             <property name="checked">
              <bool>true</bool>
