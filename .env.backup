# ══════════════════════════════════════════════════════════════════════════════
# upbit-trader 통합 환경 설정 (.env)
# 목적: Docker Compose + Python 앱 중앙 설정
# 인코딩: UTF-8 without BOM (필수)
# 버전: v2.0 (2026-04-13)
# ══════════════════════════════════════════════════════════════════════════════

# ── TimescaleDB (Tier 2: Warm Storage) ────────────────────────────────────────
# Python 앱 연결 정보
PGHOST=127.0.0.1
PGPORT=58529
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=upbit_trader
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:58529/upbit_trader

# 표준화된 환경변수
POSTGRES_HOST=127.0.0.1
POSTGRES_DB=upbit_trader

# Docker Compose 전용 (컨테이너 내부)
POSTGRES_USER_CONTAINER=postgres
POSTGRES_PASSWORD_CONTAINER=postgres
POSTGRES_DB_CONTAINER=upbit_trader
POSTGRES_PORT_CONTAINER=58529

# ── PostgreSQL CQRS (Tier 3: Core Storage) ────────────────────────────────────
# Primary (쓰기 전용)
POSTGRES_PRIMARY_USER=admin
POSTGRES_PRIMARY_PASSWORD=secret

# Replica (읽기 전용)
POSTGRES_REPLICA_USER=admin
POSTGRES_REPLICA_PASSWORD=secret

# ── Redis (Tier 1: Hot Storage) ───────────────────────────────────────────────
# Python 앱 연결 정보
REDIS_HOST=127.0.0.1
REDIS_PORT=58530
REDIS_PASSWORD=
REDIS_DB=0

# Docker Compose 전용
REDIS_PASSWORD_CONTAINER=
REDIS_PORT_CONTAINER=58530

# ── MongoDB (Tier 3: Core Storage) ────────────────────────────────────────────
# Python 앱 연결 정보 (개발 환경 - 인증 비활성화)
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_URI=mongodb://localhost:27017/upbit_trader

# Docker Compose 전용 (빈 값 = 인증 비활성화)
MONGO_INITDB_ROOT_USERNAME_CONTAINER=
MONGO_INITDB_ROOT_PASSWORD_CONTAINER=
MONGO_INITDB_DATABASE_CONTAINER=upbit_trader

# ── Kafka (Tier 4: Event Stream) ──────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://localhost:9092
KAFKA_TOPIC_ORDERS=trading.orders
KAFKA_TOPIC_TRADES=trading.trades
KAFKA_TOPIC_CANDLES=trading.candles
KAFKA_REPLICATION_FACTOR=1

# ── ClickHouse (Tier 4: OLAP) ─────────────────────────────────────────────────
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=8123
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=trader
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_DB=trading_events

# ── 모니터링 스택 ─────────────────────────────────────────────────────────────
# Grafana
GRAFANA_ADMIN_PASSWORD=admin

# Vault (DEV 모드 전용)
VAULT_DEV_TOKEN=root

# ── 데이터 수집 설정 ──────────────────────────────────────────────────────────
# 수집 모드 (auto: 앱 시작 시 자동 수집)
DATA_COLLECTION_MODE=auto

# 수집 타임프레임 (쉼표 구분)
ENABLED_TIMEFRAMES=1m,5m,1h

# Gap Detection 설정
GAP_GRACE_PERIOD_SECONDS=300
GAP_MIN_THRESHOLD_SECONDS=600
GAP_QUEUE_MAX_SIZE=50000
FORCE_ENQUEUE_LOOKBACK_DAYS=3

# ── API Rate Limit ────────────────────────────────────────────────────────────
UPBIT_API_CALLS_PER_SEC=8

# ── TimescaleDB 최적화 ────────────────────────────────────────────────────────
TIMESCALE_BATCH_SIZE=200
TIMESCALE_MAX_CONNECTIONS=50
TIMESCALE_COMPRESSION_DAYS=1
TIMESCALE_RETENTION_DAYS=90

# ── Upbit API (선택 사항) ─────────────────────────────────────────────────────
# UPBIT_ACCESS_KEY=your_access_key_here
# UPBIT_SECRET_KEY=your_secret_key_here

# ── AI/ML (선택 사항) ─────────────────────────────────────────────────────────
# AI_ML_ENABLED=false
# MLFLOW_TRACKING_URI=http://localhost:5000